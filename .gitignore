# ============================================================
# CBT Diary App .gitignore
# Backend: Python / FastAPI
# Frontend: Flutter
# OS: Windows / macOS / Linux
# ============================================================


# ============================================================
# Environment variables / secrets
# ============================================================

.env
.env.*
!.env.example

*.key
*.pem
*.crt
*.p12
*.jks

# Если случайно создашь файлы с секретами
secrets/
credentials/
keys/


# ============================================================
# Python / FastAPI backend
# ============================================================

__pycache__/
*.py[cod]
*$py.class

*.so

.Python
.python-version

# Virtual environments
venv/
.venv/
env/
ENV/
backend/venv/
backend/.venv/

# Python packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Pytest / coverage / mypy / ruff
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pyre/

# Logs
*.log
logs/
backend/logs/

# Local SQLite / databases / dumps
*.sqlite
*.sqlite3
*.db
*.dump
*.sql
*.backup

# Alembic local temp files, если появятся
alembic/versions/__pycache__/


# ============================================================
# Flutter frontend
# ============================================================

frontend/lib/utils/constants.dart
frontend/.dart_tool/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/.packages
frontend/build/
frontend/.pub-cache/
frontend/.pub/
frontend/pubspec.lock

# Flutter generated
frontend/**/generated_plugin_registrant.dart

# Coverage
frontend/coverage/

# Android / Gradle
frontend/android/.gradle/
frontend/android/local.properties
frontend/android/app/debug/
frontend/android/app/profile/
frontend/android/app/release/
frontend/android/app/*.apk
frontend/android/app/*.aab
frontend/android/key.properties

# iOS / macOS build files
frontend/ios/Pods/
frontend/ios/.symlinks/
frontend/ios/Flutter/Flutter.framework
frontend/ios/Flutter/Flutter.podspec
frontend/ios/Flutter/Generated.xcconfig
frontend/ios/Flutter/ephemeral/
frontend/ios/Runner/GeneratedPluginRegistrant.*

frontend/macos/Pods/
frontend/macos/.symlinks/
frontend/macos/Flutter/ephemeral/
frontend/macos/Flutter/GeneratedPluginRegistrant.*

# Web build
frontend/web/.dart_tool/
frontend/web/build/

# Windows / Linux generated build files
frontend/windows/flutter/ephemeral/
frontend/linux/flutter/ephemeral/


# ============================================================
# IDE / editors
# ============================================================

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# IntelliJ IDEA / Android Studio
.idea/
*.iml
*.ipr
*.iws

# Fleet
.fleet/

# Cursor / other AI editor local config
.cursor/


# ============================================================
# OS files
# ============================================================

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~


# ============================================================
# OneDrive / temporary files
# ============================================================

~$*
*.tmp
*.temp
*.bak
*.swp
*.swo


# ============================================================
# Node / web tooling, если случайно появится
# ============================================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# ============================================================
# Docker local files
# ============================================================

docker-compose.override.yml
.docker/

